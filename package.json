{
  "name": "centermasr",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "CenterMasr ERP - Desktop Application",
  "bin": "server/index.mjs",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "build:exe": "npx @yao-pkg/pkg . --output CenterMasrServer.exe",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "pkg": {
    "targets": ["node22-win-x64"],
    "assets": ["dist/**/*", "public/**/*"],
    "outputPath": "dist-exe"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jsbarcode": "^3.11.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/xlsx": "^0.0.35",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^10.0.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
